generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum PlanTier {
  FREE
  PLUS
  PRO
}
enum UserRole {
  USER
  ADMIN
}enum

enum TaskType {
  DEEP_WORK
  STUDY
  CREATIVE
  ADMIN
  ROUTINE
  PERSONAL
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  FULFILLED
}

enum PaymentProvider {
  BANK_TRANSFER
  SEPAY
  MOMO
  ZALOPAY
  VNPAY
}

enum PaymentOrderStatus {
  PENDING
  PAID
  EXPIRED
  CANCELLED
  AMOUNT_MISMATCH
  FAILED
  REFUNDED
}

enum FocusSessionStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum RewardRedemptionStatus {
  PENDING
  APPROVED
  REJECTED
  FULFILLED
}

model User {
  id           String  @id @default(cuid())
  name         String
  email        String  @unique
  passwordHash String?
  studentId    String?

  role                   UserRole  @default(USER)
  chronotype             String?
  hasCompletedAssessment Boolean   @default(false)
  lastAssessmentAt       DateTime?
  coinBalance            Int       @default(0)
  targetSleepTime        String?
  targetWakeTime         String?
  image                  String?

  // Tracking for pitching / marketing / customer records
  customerType       String?
  sourceChannel      String?
  sourceCampaign     String?
  sourceMedium       String?
  sourceContent      String?
  sourceTerm         String?
  companyName        String?
  roleInCompany      String?
  teamSize           Int?
  consentForResearch Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts          Account[]
  sessions          Session[]
  chronotypeResults ChronotypeResult[]
  tasks             Task[]
  weeklyInsights    WeeklyInsight[]
  orders            Order[]
  paymentOrders     PaymentOrder[]
  focusSessions     FocusSession[]
  rewardRedemptions RewardRedemption[]
  energyCheckins    EnergyCheckin[]
  streakRewards     StreakReward[]
  coinTransactions  CoinTransaction[]

  feedbackResponses      FeedbackResponse[]
  marketingDailyRecords  MarketingDailyRecord[]
  financialDailyRecords  FinancialDailyRecord[]
  businessMeetingRecords BusinessMeetingRecord[]
}

model CoinTransaction {
  id           String   @id @default(cuid())
  userId       String
  type         String
  amount       Int
  balanceAfter Int
  sourceType   String?
  sourceId     String?
  description  String
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model FeedbackResponse {
  id                 String   @id @default(cuid())
  userId             String?
  name               String?
  email              String?
  rating             Int
  userType           String?
  sourceChannel      String?
  whatWorked         String
  whatConfused       String?
  featureRequest     String?
  wouldRecommend     Boolean  @default(false)
  testimonialConsent Boolean  @default(false)
  contactConsent     Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([rating])
  @@index([userType])
  @@index([sourceChannel])
  @@index([createdAt])
}

model MarketingDailyRecord {
  id                    String   @id @default(cuid())
  date                  DateTime
  channel               String
  contentTitle          String
  contentType           String
  views                 Int      @default(0)
  likes                 Int      @default(0)
  comments              Int      @default(0)
  shares                Int      @default(0)
  clicks                Int      @default(0)
  followersDelta        Int      @default(0)
  signups               Int      @default(0)
  assessmentCompletions Int      @default(0)
  notes                 String?
  proofUrl              String?
  createdById           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([date])
  @@index([channel])
  @@index([createdById])
}

model FinancialDailyRecord {
  id                  String   @id @default(cuid())
  date                DateTime
  revenue             Int      @default(0)
  payingCustomers     Int      @default(0)
  productPackage      String?
  paymentMethod       String?
  transactionCode     String?
  transactionProofUrl String?
  marketingCost       Int      @default(0)
  otherCost           Int      @default(0)
  profit              Int      @default(0)
  notes               String?
  createdById         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([date])
  @@index([paymentMethod])
  @@index([createdById])
}

model BusinessMeetingRecord {
  id              String    @id @default(cuid())
  meetingDate     DateTime
  companyName     String
  contactPerson   String?
  contactRole     String?
  demoUsers       Int       @default(0)
  userCount       Int       @default(0)
  painPoints      String?
  feedback        String?
  featureRequests String?
  outcome         String?
  evidenceUrl     String?
  followUpDate    DateTime?
  createdById     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([meetingDate])
  @@index([companyName])
  @@index([outcome])
  @@index([createdById])
}

model ChronotypeResult {
  id           String   @id @default(cuid())
  userId       String
  chronotype   String
  lionScore    Int
  bearScore    Int
  wolfScore    Int
  dolphinScore Int
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Task {
  id            String   @id @default(cuid())
  userId        String
  name          String
  type          TaskType
  priority      Priority
  duration      String
  deadline      String?
  scheduledTime String
  explanation   String
  completed     Boolean  @default(false)

  isBacklog     Boolean @default(false)
  scheduledDate String?
  startTime     String?
  endTime       String?
  focusMode     String?
  focusMinutes  Int?
  orderIndex    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  focusSessions FocusSession[]

  @@index([userId, createdAt])
  @@index([userId, scheduledDate])
}

model FocusSession {
  id     String             @id @default(cuid())
  userId String
  taskId String?
  status FocusSessionStatus @default(ACTIVE)

  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  durationMinutes Int       @default(0)
  coinsEarned     Int       @default(0)

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([taskId])
  @@index([status])
  @@index([startedAt])
}

model EnergyCheckin {
  id        String   @id @default(cuid())
  userId    String
  score     Int
  note      String?
  source    String   @default("MANUAL")
  checkedAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, checkedAt])
  @@index([source])
}

model WeeklyInsight {
  id             String   @id @default(cuid())
  userId         String
  weekLabel      String
  alignmentScore Int
  completedCount Int
  totalCount     Int
  deepWorkCount  Int
  recommendation String
  summary        String
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekLabel])
  @@index([userId, createdAt])
}

model Article {
  id        String        @id @default(cuid())
  slug      String        @unique
  title     String
  category  String
  readTime  String
  color     String?
  intro     String
  body      Json
  status    ContentStatus @default(DRAFT)
  featured  Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Product {
  id               String        @id @default(cuid())
  slug             String        @unique
  name             String
  badge            String?
  price            String
  shortDescription String
  features         Json
  shippingNote     String?
  usageFlow        Json
  status           ContentStatus @default(PUBLISHED)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  orders Order[]
}

model Order {
  id          String      @id @default(cuid())
  userId      String
  productId   String
  quantity    Int         @default(1)
  totalAmount String
  status      OrderStatus @default(PENDING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model PaymentOrder {
  id     String  @id @default(cuid())
  userId String?

  itemKey  String
  itemName String
  itemType String @default("subscription")

  amount   Int
  currency String @default("VND")

  provider PaymentProvider    @default(SEPAY)
  status   PaymentOrderStatus @default(PENDING)

  transferCode String  @unique
  qrUrl        String?

  bankId      String?
  accountNo   String?
  accountName String?

  paidAmount Int?
  paidAt     DateTime?

  providerTxnId      String? @unique
  sepayTransactionId String?
  sepayReferenceCode String?
  sepayGateway       String?
  sepayAccountNumber String?
  sepayContent       String?

  rawWebhook Json?

  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, createdAt])
  @@index([itemKey])
  @@index([provider])
  @@index([status])
  @@index([transferCode])
  @@index([createdAt])
}

model RewardItem {
  id          String  @id @default(cuid())
  slug        String  @unique
  title       String
  description String?
  pointsCost  Int
  active      Boolean @default(true)

  imageUrl     String?
  category     String  @default("PHYSICAL")
  stock        Int?
  perUserLimit Int     @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  redemptions RewardRedemption[]

  @@index([active])
  @@index([category])
  @@index([pointsCost])
}

model RewardRedemption {
  id     String @id @default(cuid())
  userId String

  rewardItemId String?
  rewardItem   RewardItem? @relation(fields: [rewardItemId], references: [id], onDelete: SetNull)

  rewardId    String
  rewardTitle String
  pointsCost  Int

  recipientName String
  phone         String
  address       String
  note          String?

  status RewardRedemptionStatus @default(PENDING)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([rewardItemId])
  @@index([rewardId])
  @@index([status])
  @@index([createdAt])
}

model StreakReward {
  id          String   @id @default(cuid())
  userId      String
  milestone   Int
  coinsEarned Int
  awardedAt   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, milestone])
  @@index([userId])
  @@index([awardedAt])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}
